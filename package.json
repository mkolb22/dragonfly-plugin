{
  "name": "@dragonflymcp/plugin",
  "version": "1.0.6",
  "description": "Dragonfly MCP Plugin — Sonnet-optimized code intelligence, memory, and workflow tools",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist/",
    "templates/",
    "scripts/",
    ".claude-plugin/"
  ],
  "bin": {
    "dragonfly-init": "scripts/init.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "postinstall": "node scripts/init.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "better-sqlite3": "^11.10.0",
    "fast-glob": "^3.3.3",
    "web-tree-sitter": "^0.24.7",
    "tree-sitter-wasms": "^0.1.13",
    "@huggingface/transformers": "^3.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.0",
    "@vitest/coverage-v8": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0",
    "eslint": "^9.39.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT AND Commons-Clause",
  "author": {
    "name": "Michael Kolb",
    "url": "https://github.com/mkolb22"
  },
  "homepage": "https://github.com/mkolb22/dragonfly-plugin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkolb22/dragonfly-plugin.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "ast",
    "semantic-search",
    "test-generation",
    "code-repair",
    "claude-code",
    "dragonfly",
    "sonnet"
  ]
}
