validation:
  # Every skill referenced by an agent must exist in skills section
  all_references_valid: true

  # Skills must have at least one user (except meta skills)
  no_orphaned_skills: true

  # P0 skills must be used by at least 2 agents
  p0_multi_agent: true

  # Validation errors will be logged during install
  strict_mode: false  # Set to true to fail install on errors

