{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dragonfly.dev/schemas/review.schema.json",
  "title": "Dragonfly Review Schema",
  "description": "Schema for code review state files in data/reviews/",
  "type": "object",
  "required": ["review_id", "impl_id", "status", "summary", "files_reviewed"],
  "properties": {
    "review_id": {
      "type": "string",
      "pattern": "^review-[0-9]{3,}$",
      "description": "Unique review identifier"
    },
    "impl_id": {
      "type": "string",
      "pattern": "^impl-[0-9]{3,}$",
      "description": "Reference to the implementation being reviewed"
    },
    "status": {
      "type": "string",
      "enum": ["approved", "needs_changes", "rejected"],
      "description": "Review outcome"
    },
    "summary": {
      "type": "object",
      "required": ["overall_quality", "blocking_issues", "total_issues"],
      "properties": {
        "overall_quality": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "blocking_issues": {
          "type": "integer",
          "minimum": 0
        },
        "total_issues": {
          "type": "integer",
          "minimum": 0
        },
        "recommendation": {
          "type": "string"
        }
      }
    },
    "files_reviewed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "status"],
        "properties": {
          "path": {
            "type": "string",
            "description": "File path"
          },
          "status": {
            "type": "string",
            "enum": ["approved", "needs_changes"]
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["severity", "category", "issue"],
              "properties": {
                "line": {
                  "type": "integer",
                  "minimum": 1
                },
                "severity": {
                  "type": "string",
                  "enum": ["critical", "major", "minor", "suggestion"]
                },
                "category": {
                  "type": "string",
                  "enum": ["security", "performance", "maintainability", "correctness", "style"]
                },
                "issue": {
                  "type": "string",
                  "description": "Description of the issue"
                },
                "suggestion": {
                  "type": "string",
                  "description": "How to fix it"
                },
                "code_before": {
                  "type": "string"
                },
                "code_after": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "description": "IDE diagnostics from mcp__ide__getDiagnostics (TypeScript, ESLint)",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "not_run"],
          "description": "Overall diagnostics status"
        },
        "errors": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of errors (severity=1, blocking)"
        },
        "warnings": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of warnings (severity=2)"
        },
        "files_checked": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of files checked for diagnostics"
        },
        "summary": {
          "type": "string",
          "description": "One-line summary of diagnostics results"
        },
        "blocking_issues": {
          "type": "array",
          "description": "Errors that block the review",
          "items": {
            "type": "object",
            "required": ["file", "line", "code", "severity", "source", "message"],
            "properties": {
              "file": {
                "type": "string",
                "description": "File path"
              },
              "line": {
                "type": "integer",
                "minimum": 1,
                "description": "Line number"
              },
              "code": {
                "type": "string",
                "description": "Diagnostic code (e.g., TS2345, no-unused-vars)"
              },
              "severity": {
                "type": "string",
                "enum": ["error", "warning"],
                "description": "Severity level"
              },
              "source": {
                "type": "string",
                "description": "Diagnostic source (e.g., TypeScript, ESLint)"
              },
              "message": {
                "type": "string",
                "description": "Diagnostic message"
              },
              "suggestion": {
                "type": "string",
                "description": "Suggested fix"
              }
            }
          }
        },
        "warnings_detail": {
          "type": "array",
          "description": "Non-blocking warnings",
          "items": {
            "type": "object",
            "required": ["file", "line", "code", "severity", "source", "message"],
            "properties": {
              "file": {
                "type": "string"
              },
              "line": {
                "type": "integer",
                "minimum": 1
              },
              "code": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": ["warning"]
              },
              "source": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        },
        "action_required": {
          "type": "string",
          "description": "What needs to be done to pass diagnostics"
        }
      }
    },
    "security_checklist": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "status"],
        "properties": {
          "check": {
            "type": "string",
            "description": "Security check performed"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "n/a"]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "performance_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "positive_feedback": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Things done well"
    },
    "test_coverage_assessment": {
      "type": "object",
      "properties": {
        "estimated_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "missing_tests": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "approved" }
        }
      },
      "then": {
        "properties": {
          "summary": {
            "properties": {
              "blocking_issues": { "const": 0 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "diagnostics": {
            "properties": {
              "errors": { "minimum": 1 }
            }
          }
        }
      },
      "then": {
        "properties": {
          "status": { "enum": ["needs_changes", "rejected"] }
        }
      }
    }
  ]
}
