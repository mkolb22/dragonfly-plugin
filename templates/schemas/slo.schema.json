{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dragonfly.dev/schemas/slo.schema.json",
  "title": "Dragonfly SLO Schema",
  "description": "Schema for Service Level Objectives configuration, metrics, violations, and reports",
  "definitions": {
    "slo-config": {
      "title": "SLO Configuration",
      "description": "SLO expectations block in synchronization rules",
      "type": "object",
      "properties": {
        "expected_duration_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Target execution duration in milliseconds"
        },
        "max_duration_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum acceptable duration (timeout threshold)"
        },
        "expected_cost_usd": {
          "type": "number",
          "minimum": 0,
          "description": "Target cost in USD"
        },
        "max_cost_usd": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum acceptable cost"
        },
        "expected_context_tokens": {
          "type": "number",
          "minimum": 0,
          "description": "Expected context tokens with optimizations"
        },
        "max_context_tokens": {
          "type": "number",
          "minimum": 0,
          "maximum": 200000,
          "description": "Maximum context tokens before alert"
        },
        "success_rate_target": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Target success rate (0.0 to 1.0)"
        },
        "on_timeout": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["retry", "escalate", "alert"]
            },
            "max_retries": {
              "type": "number",
              "minimum": 0
            },
            "backoff_ms": {
              "type": "number",
              "minimum": 0,
              "default": 1000
            },
            "on_exhausted": {
              "type": "string",
              "enum": ["escalate", "alert", "block"]
            }
          },
          "required": ["action"]
        },
        "on_cost_exceeded": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["alert", "block"]
            },
            "continue": {
              "type": "boolean",
              "description": "Whether to continue workflow after alert"
            },
            "notify": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Notification channels"
            }
          },
          "required": ["action"]
        },
        "on_context_exceeded": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["alert", "investigate"]
            },
            "investigate": {
              "type": "boolean",
              "description": "Create investigation task"
            }
          },
          "required": ["action"]
        },
        "on_quality_below_target": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["alert", "escalate"]
            },
            "threshold_count": {
              "type": "number",
              "minimum": 1,
              "description": "Number of failures before action"
            }
          },
          "required": ["action"]
        }
      }
    },
    "slo-metrics": {
      "title": "SLO Monthly Metrics",
      "description": "Aggregated monthly metrics per concept",
      "type": "object",
      "required": ["concept", "period", "total_executions", "compliance_rate", "status"],
      "properties": {
        "concept": {
          "type": "string",
          "description": "Concept name (e.g., architecture)"
        },
        "period": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$",
          "description": "Month in YYYY-MM format"
        },
        "total_executions": {
          "type": "number",
          "minimum": 0,
          "description": "Total action executions this period"
        },
        "compliance_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Overall compliance rate (0.0 to 1.0)"
        },
        "status": {
          "type": "string",
          "enum": ["healthy", "degraded", "critical"],
          "description": "Overall health status"
        },
        "details": {
          "type": "object",
          "properties": {
            "duration": {
              "type": "object",
              "properties": {
                "p50_ms": {"type": "number"},
                "p95_ms": {"type": "number"},
                "p99_ms": {"type": "number"},
                "max_ms": {"type": "number"},
                "violations": {"type": "number", "minimum": 0}
              }
            },
            "cost": {
              "type": "object",
              "properties": {
                "average_usd": {"type": "number"},
                "p95_usd": {"type": "number"},
                "total_usd": {"type": "number"},
                "violations": {"type": "number", "minimum": 0}
              }
            },
            "context": {
              "type": "object",
              "properties": {
                "average_tokens": {"type": "number"},
                "p95_tokens": {"type": "number"},
                "max_tokens": {"type": "number"},
                "violations": {"type": "number", "minimum": 0}
              }
            },
            "success_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "slo_config_snapshot": {
              "$ref": "#/definitions/slo-config"
            }
          }
        }
      }
    },
    "slo-violation": {
      "title": "SLO Violation Record",
      "description": "Individual violation with handler execution details",
      "type": "object",
      "required": ["violation_id", "timestamp", "concept", "type", "severity"],
      "properties": {
        "violation_id": {
          "type": "string",
          "pattern": "^viol-[0-9]+$",
          "description": "Unique violation identifier"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When violation occurred"
        },
        "concept": {
          "type": "string",
          "description": "Concept that violated SLO"
        },
        "type": {
          "type": "string",
          "enum": ["timeout", "cost_exceeded", "context_exceeded", "quality_below_target"],
          "description": "Type of violation"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Violation severity"
        },
        "details": {
          "type": "object",
          "properties": {
            "action_id": {"type": "string"},
            "flow_id": {"type": "string"},
            "sync_id": {"type": "string"},
            "expected": {
              "type": "object",
              "properties": {
                "threshold_name": {"type": "string"},
                "threshold_value": {"type": "number"}
              }
            },
            "actual": {
              "type": "object",
              "properties": {
                "value": {"type": "number"},
                "deviation_percent": {"type": "number"}
              }
            },
            "handler_executed": {
              "type": "object",
              "properties": {
                "action": {"type": "string"},
                "retries_attempted": {"type": "number"},
                "final_action": {"type": "string"}
              }
            },
            "resolution": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["pending", "resolved", "ignored"]
                },
                "resolved_at": {"type": "string", "format": "date-time"},
                "resolved_by": {"type": "string"},
                "notes": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "slo-report": {
      "title": "SLO Performance Report",
      "description": "Generated performance dashboard",
      "type": "object",
      "required": ["report_id", "generated_at", "timeframe"],
      "properties": {
        "report_id": {
          "type": "string",
          "description": "Unique report identifier"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "timeframe": {
          "type": "string",
          "enum": ["1d", "7d", "30d", "all"],
          "description": "Report period"
        },
        "executive_summary": {
          "type": "object",
          "properties": {
            "overall_compliance": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "concepts_healthy": {"type": "number", "minimum": 0},
            "concepts_degraded": {"type": "number", "minimum": 0},
            "concepts_critical": {"type": "number", "minimum": 0},
            "total_violations": {"type": "number", "minimum": 0},
            "top_issues": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "by_concept": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "concept": {"type": "string"},
              "compliance": {"type": "number"},
              "status": {"type": "string"},
              "duration_stats": {
                "type": "object",
                "properties": {
                  "p50_ms": {"type": "number"},
                  "p95_ms": {"type": "number"}
                }
              },
              "cost_stats": {
                "type": "object",
                "properties": {
                  "average_usd": {"type": "number"},
                  "p95_usd": {"type": "number"}
                }
              },
              "context_stats": {
                "type": "object",
                "properties": {
                  "average_tokens": {"type": "number"},
                  "p95_tokens": {"type": "number"}
                }
              },
              "violations_count": {"type": "number", "minimum": 0}
            }
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "priority": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "issue": {"type": "string"},
              "suggested_action": {"type": "string"}
            }
          }
        }
      }
    },
    "slo-monitor-result": {
      "title": "SLO Monitor Action Result",
      "description": "Result of monitoring action against SLO",
      "type": "object",
      "required": ["compliance", "metrics_updated"],
      "properties": {
        "compliance": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "violations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/slo-violation"
          }
        },
        "metrics_updated": {"type": "boolean"},
        "metrics_file": {"type": "string"},
        "handlers_executed": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "handler": {"type": "string"},
              "action": {"type": "string"},
              "result": {"type": "string"}
            }
          }
        }
      }
    },
    "slo-alert-result": {
      "title": "SLO Alert Handler Result",
      "description": "Result of executing alert handler",
      "type": "object",
      "required": ["notification_sent", "handler_action", "result"],
      "properties": {
        "notification_sent": {"type": "boolean"},
        "handler_action": {"type": "string"},
        "result": {
          "type": "string",
          "enum": ["success", "failure"]
        },
        "next_action": {"type": "string"}
      }
    },
    "slo-validation-result": {
      "title": "SLO Configuration Validation Result",
      "description": "Result of validating SLO configurations",
      "type": "object",
      "required": ["rules_checked", "rules_valid"],
      "properties": {
        "rules_checked": {"type": "number", "minimum": 0},
        "rules_valid": {"type": "number", "minimum": 0},
        "rules_with_warnings": {"type": "number", "minimum": 0},
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rule_id": {"type": "string"},
              "message": {"type": "string"},
              "severity": {
                "type": "string",
                "enum": ["warning", "error"]
              }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  },
  "oneOf": [
    {"$ref": "#/definitions/slo-config"},
    {"$ref": "#/definitions/slo-metrics"},
    {"$ref": "#/definitions/slo-violation"},
    {"$ref": "#/definitions/slo-report"},
    {"$ref": "#/definitions/slo-monitor-result"},
    {"$ref": "#/definitions/slo-alert-result"},
    {"$ref": "#/definitions/slo-validation-result"}
  ]
}
