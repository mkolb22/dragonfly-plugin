{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dragonfly.dev/schemas/provenance.schema.json",
  "title": "Dragonfly Provenance Schema",
  "description": "Schema for action provenance files in data/provenance/actions/",
  "type": "object",
  "required": ["action_id", "concept", "action", "status", "timestamp"],
  "properties": {
    "action_id": {
      "type": "string",
      "pattern": "^act-[0-9]{3,}$",
      "description": "Unique action identifier"
    },
    "concept": {
      "type": "string",
      "enum": ["story", "architecture", "implementation", "quality", "version", "context", "retrospective"],
      "description": "Which concept performed this action"
    },
    "action": {
      "type": "string",
      "description": "The action performed (create, design, review, etc.)"
    },
    "status": {
      "type": "string",
      "enum": ["started", "completed", "failed", "blocked"],
      "description": "Outcome of the action"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the action occurred"
    },
    "model": {
      "type": "string",
      "enum": ["haiku", "sonnet", "opus"],
      "description": "Which AI model was used"
    },
    "triggered_by": {
      "type": ["string", "null"],
      "description": "Parent action ID or null if user-initiated"
    },
    "flow_id": {
      "type": "string",
      "pattern": "^flow-",
      "description": "Workflow this action belongs to"
    },
    "sync_rule_id": {
      "type": ["string", "null"],
      "description": "Sync rule that triggered this action"
    },
    "inputs": {
      "type": "object",
      "description": "Inputs provided to this action"
    },
    "outputs": {
      "type": "object",
      "description": "Outputs produced by this action",
      "properties": {
        "artifact_id": {
          "type": "string",
          "description": "ID of produced artifact (story, arch, impl, etc.)"
        },
        "artifact_type": {
          "type": "string"
        },
        "artifact_path": {
          "type": "string"
        }
      }
    },
    "cost": {
      "type": "object",
      "properties": {
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "How long the action took"
    },
    "error": {
      "type": ["object", "null"],
      "properties": {
        "type": { "type": "string" },
        "message": { "type": "string" },
        "recoverable": { "type": "boolean" }
      },
      "description": "Error details if action failed"
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata"
    }
  }
}
