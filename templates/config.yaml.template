# Dragonfly WYSIWID Configuration
# Generated by Dragonfly installer

# Model Assignment
# THIS IS THE AUTHORITATIVE SOURCE for model assignments
# Agent frontmatter must match these values
# Using Claude 4.5 models for maximum quality
models:
  concepts:
    # Core workflow concepts
    story: "sonnet"           # Opus 4.5 for story analysis
    architecture: "opus"      # Opus 4.5 for deep reasoning and design
    implementation: "sonnet"  # Opus 4.5 for code generation
    quality: "sonnet"         # Opus 4.5 for thorough review
    version: "sonnet"         # Opus 4.5 for git operations
    context: "sonnet"         # Opus 4.5 for context management
    # Extended concepts
    security: "sonnet"        # Opus 4.5 for security scanning
    documentation: "sonnet"   # Opus 4.5 for doc generation
    verification: "sonnet"    # Opus 4.5 for multi-pass review
    code-analysis: "sonnet"   # Opus 4.5 for codebase context

  # Model costs (for provenance tracking) - Claude 4.5 pricing
  costs:
    haiku:
      input: 0.00025      # per 1K tokens
      output: 0.00125     # per 1K tokens
    sonnet:
      input: 0.003        # per 1K tokens
      output: 0.015       # per 1K tokens
    opus:
      input: 0.015        # per 1K tokens
      output: 0.075       # per 1K tokens

# State Storage
# Where concepts store their state
storage:
  base_path: "data"
  directories:
    stories: "data/stories"
    architecture: "data/architecture"
    implementations: "data/implementations"
    reviews: "data/reviews"
    versions: "data/versions"
    provenance_actions: "data/provenance/actions"
    provenance_flows: "data/provenance/flows"
    session_state: "data/session-state"

# Synchronizations
# Path to synchronization rules
synchronizations:
  enabled: true
  rules_path: ".claude/synchronizations"
  auto_trigger: true  # Automatically trigger syncs after concept actions

# Provenance
# Tracking configuration
provenance:
  enabled: true
  track_costs: true
  flow_token_format: "flow-%Y-%m-%d-%Hh%Mm%Ss"
  action_id_format: "act-%s"  # %s = unix timestamp

# Context Management
# Context window management settings
context:
  budget_tokens: 200000
  warning_threshold: 0.75   # Warn at 75% usage
  critical_threshold: 0.90  # Critical at 90% usage
  auto_snapshot: true
  snapshot_triggers:
    - "workflow_complete"
    - "context_warning"
    - "session_boundary"

# Quality Gates
# Validation thresholds
quality:
  min_test_coverage: 100.0  # Required 100% coverage for all new code
  require_security_check: true
  block_on_vulnerabilities: true
  allow_low_severity_issues: true
  max_complexity: 10

# Git Integration
# Version control settings
git:
  default_branch: "main"
  branch_format: "feature/%s-%s"  # story-id, slug
  commit_format: "conventional"   # conventional commits
  require_tests: true
  auto_push: false  # Manual push only

# Feature Flags
# Enable/disable features
features:
  auto_synchronization: true
  provenance_tracking: true
  cost_tracking: true
  context_monitoring: true
  quality_gates: true
  mcp_caching: true         # Cache MCP server results

# MCP Configuration
# Model Context Protocol server settings
mcp:
  cache:
    enabled: true
    storage: "data/mcp-cache"
    ttl_seconds: 3600        # Cache valid for 1 hour
    max_entries: 1000        # Max cached entries
    eviction_policy: "lru"   # least-recently-used

  servers:
    ast-index:
      enabled: true
      cache_tools:
        - "find_symbol"       # Cache symbol lookups
        - "get_file_symbols"  # Cache file symbols
        - "get_call_graph"    # Cache call graphs
      cache_ttl_seconds: 7200  # 2 hours for AST (code changes infrequently)

    semantic-rag:
      enabled: true
      cache_tools:
        - "semantic_search"   # Cache semantic search results
        - "find_similar"      # Cache similarity results
      cache_ttl_seconds: 1800  # 30 min for RAG (embeddings may update)

  # Fallback behavior when MCP unavailable
  fallback:
    strategy: "graceful"      # graceful | strict | retry
    max_retries: 2
    retry_backoff_ms: 2000
    continue_without: true    # Continue workflow without MCP if unavailable

# Logging
# Debug and monitoring
logging:
  level: "info"  # debug, info, warn, error
  log_concept_actions: true
  log_synchronizations: true
  log_provenance: true

# Project Metadata
# Information about this project
project:
  name: "Data"
  description: "Reference implementation of Dragonfly WYSIWID architecture"
  version: "1.0.0"
  created_at: "2025-11-09"

# Concept Execution
# How concepts are invoked
execution:
  method: "task-tool"  # Claude Code Task tool
  timeout: 300         # 5 minutes per action
  retry_on_failure: true
  max_retries: 1

# Synchronization Engine
# How syncs are evaluated and triggered
sync_engine:
  evaluation_mode: "immediate"  # immediate, batch, or manual
  parallel_execution: true      # Allow parallel sync triggers
  max_parallel: 3              # Max concurrent concept invocations

# Sync Dependencies
# Explicit dependency declarations for synchronization rules
# Ensures correct execution order and prevents race conditions
sync_dependencies:
  # Core workflow dependencies (feature-development.yaml)
  workflow:
    # Phase 1: Story must complete before code-analysis or architecture
    story-to-code-analysis:
      requires: []  # Entry point
      provides: ["code_analysis"]

    story-to-arch:
      requires: ["story.ready"]
      provides: ["architecture_draft"]
      fallback_for: "story-to-code-analysis"  # Used when code-analysis skipped

    code-analysis-to-arch:
      requires: ["code_analysis"]
      provides: ["architecture_draft"]

    # Phase 2: Architecture must complete before implementation
    arch-to-impl:
      requires: ["architecture_draft", "architecture.approved"]
      provides: ["implementation"]

    arch-high-risk-approval:
      requires: ["architecture_draft"]
      provides: ["architecture.approved", "architecture.rejected"]
      decision_point: true

    # Phase 3: Implementation must complete before quality
    impl-to-quality-review:
      requires: ["implementation"]
      provides: ["review_result"]
      parallel_with: ["impl-to-quality-test"]

    impl-to-quality-test:
      requires: ["implementation"]
      provides: ["test_result"]
      parallel_with: ["impl-to-quality-review"]

    # Phase 4: Both quality checks must complete before version
    quality-to-version:
      requires: ["review_result", "test_result"]
      requires_all: true  # ALL dependencies must be satisfied
      provides: ["commit"]

  # Verification dependencies (verification-flow.yaml)
  verification:
    arch-verify-pass-1:
      requires: ["architecture_draft"]
      provides: ["verification_pass_1"]

    arch-verify-pass-2:
      requires: ["verification_pass_1"]
      provides: ["verification_pass_2"]

    arch-verify-consensus:
      requires: ["verification_pass_1", "verification_pass_2"]
      requires_all: true
      provides: ["verification_consensus"]

    arch-consensus-approved:
      requires: ["verification_consensus"]
      provides: ["implementation"]

    arch-consensus-blocked:
      requires: ["verification_consensus"]
      provides: ["architecture_revision"]

    impl-verify-pass-1:
      requires: ["implementation"]
      provides: ["impl_verification_pass_1"]

    impl-verify-pass-2:
      requires: ["impl_verification_pass_1"]
      provides: ["impl_verification_pass_2"]

    impl-verify-consensus:
      requires: ["impl_verification_pass_1", "impl_verification_pass_2"]
      requires_all: true
      provides: ["impl_verification_consensus"]

  # Documentation dependencies (documentation-flow.yaml)
  documentation:
    story-to-requirements-docs:
      requires: ["story.ready"]
      provides: ["requirements_doc"]
      parallel_with: ["story-to-code-analysis"]

    arch-to-architecture-docs:
      requires: ["architecture_draft"]
      provides: ["architecture_doc"]
      parallel_with: ["arch-to-impl"]

    impl-to-api-docs:
      requires: ["implementation"]
      provides: ["api_doc"]
      parallel_with: ["impl-to-quality-review", "impl-to-quality-test"]

    quality-to-test-docs:
      requires: ["test_result"]
      provides: ["test_doc"]

    pre-commit-doc-validation:
      requires: ["review_result", "requirements_doc", "architecture_doc", "api_doc"]
      provides: ["doc_validation"]

    post-commit-doc-index:
      requires: ["commit", "doc_validation"]
      provides: ["doc_index"]

  # Dependency resolution settings
  resolution:
    timeout_ms: 30000           # Max wait for dependencies
    poll_interval_ms: 500       # How often to check
    fail_on_missing: false      # Continue if optional dep missing
    circular_detection: true    # Detect circular dependencies
    log_resolution: true        # Log dependency resolution

# Cost Optimization
# Smart model assignment strategy - Claude 4.5 models
optimization:
  strategy: "smart_assignment"

  # When to use Opus 4.5 (most expensive, deepest reasoning)
  use_opus_for:
    - "architecture.design"
    - "architecture.revise"
    - "architecture.evaluate_tradeoffs"

  # When to use Opus 4.5 (balanced quality and cost)
  use_sonnet_for:
    - "story.*"          # All story actions
    - "implementation.*" # All implementation actions
    - "quality.*"        # All quality actions
    - "version.*"        # All version actions
    - "context.*"        # All context actions
    - "security.*"       # All security actions
    - "documentation.*"  # All documentation actions
    - "verification.*"   # All verification actions
    - "code-analysis.*"  # All code analysis actions

  # Cost tracking
  track_savings: true
  report_efficiency: true

  # Cost budget (optional - set to enable budget approval)
  cost_budget: 0.010  # Default: $0.01 per feature (2.5x typical cost)
  budget_enabled: false  # Set to true to enable budget approval prompts

# Security
# Security-related settings
security:
  check_owasp_top_10: true
  block_on_critical: true
  scan_dependencies: false  # Requires external tools
  audit_git_hooks: true

# Documentation
# Where to find help
documentation:
  concepts: ".claude/concepts/README.md"
  synchronizations: ".claude/synchronizations/feature-development.yaml"
  commands: ".claude/commands/"
  examples: "docs/examples/"

# Hooks
# Event-driven automation
hooks:
  enabled: true
  hooks_path: ".claude/hooks"
  post_concept_action: "post-concept-action"

# Experimental Features
# Not yet stable
experimental:
  sync_mocking: false      # Mock concepts for testing syncs
  architecture_lint: false # Static analysis of concept dependencies
  ai_cost_prediction: false # Predict cost before execution
