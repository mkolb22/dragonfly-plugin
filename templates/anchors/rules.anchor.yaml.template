# Dragonfly Immutable Rules Anchor
# This file is re-injected into context to prevent primacy decay
#
# IMMUTABLE: Contents survive context compression
# Claude should read this file when uncertain about project rules

anchor_id: "anchor-rules"
type: "rules"
immutable: true
created_at: "${TIMESTAMP}"
last_updated: "${TIMESTAMP}"

# Core safety rules - NEVER violate these
safety_rules:
  - id: "safety-001"
    text: "Never run rm -rf without explicit user confirmation"
    priority: critical

  - id: "safety-002"
    text: "Never run git reset --hard without explicit user confirmation"
    priority: critical

  - id: "safety-003"
    text: "Verify current working directory before file operations"
    priority: critical

  - id: "safety-004"
    text: "Never execute database DROP or TRUNCATE without explicit confirmation"
    priority: critical

# Workflow rules - follow these for consistency
workflow_rules:
  - id: "workflow-001"
    text: "Create git commits only when explicitly requested by user"
    priority: high

  - id: "workflow-002"
    text: "Run tests before committing code changes"
    priority: high

  - id: "workflow-003"
    text: "Use the WYSIWID pattern - behavior should be visible in configuration"
    priority: medium

# Project-specific rules - customize per project
#
# ADD YOUR CORE PRINCIPLES HERE. These rules:
# - Survive context compression (injected by pre-compact hook)
# - Are re-read at session start
# - Guide Claude's behavior throughout the project
#
# Use /remember to store general knowledge. Use this file for
# non-negotiable principles that must persist across all sessions.
#
project_rules: []
# Example:
# - id: "project-001"
#   text: "All work MUST use /feature or /workflow commands"
#   priority: critical
#
# - id: "project-002"
#   text: "Refactor until DRY"
#   priority: high

# When to re-read this file
triggers:
  - "After context compression"
  - "Before destructive operations"
  - "When uncertain about project conventions"
  - "At session start"
