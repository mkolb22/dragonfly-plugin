# Dragonfly Safety Constraints Anchor
# Defines safety boundaries that must never be crossed
#
# IMMUTABLE: These constraints are non-negotiable
# Claude should check this before any potentially destructive operation

anchor_id: "anchor-safety"
type: "safety"
immutable: true
created_at: "${TIMESTAMP}"
last_updated: "${TIMESTAMP}"

# Operations that are ALWAYS blocked
blocked_operations:
  filesystem:
    - pattern: "rm -rf /"
      reason: "Would delete entire filesystem"
    - pattern: "rm -rf ~"
      reason: "Would delete user home directory"
    - pattern: "rm -rf $HOME"
      reason: "Would delete user home directory"
    - pattern: "> /dev/sd*"
      reason: "Would overwrite disk device"
    - pattern: "mkfs.*"
      reason: "Would format disk"
    - pattern: "dd if=*"
      reason: "Raw disk write - extremely dangerous"

  git:
    - pattern: "git push --force origin main"
      reason: "Would overwrite shared main branch history"
    - pattern: "git push --force origin master"
      reason: "Would overwrite shared master branch history"

  database:
    - pattern: "DROP DATABASE production"
      reason: "Would destroy production database"

# Operations that require explicit user confirmation
requires_confirmation:
  filesystem:
    - pattern: "rm -rf"
      prompt: "This will recursively delete files. Are you sure?"
    - pattern: "rm -r"
      prompt: "This will recursively delete files. Are you sure?"

  git:
    - pattern: "git reset --hard"
      prompt: "This will discard uncommitted changes. Are you sure?"
    - pattern: "git clean -fd"
      prompt: "This will delete untracked files. Are you sure?"
    - pattern: "git checkout -- ."
      prompt: "This will discard all local changes. Are you sure?"
    - pattern: "git branch -D"
      prompt: "This will force-delete a branch. Are you sure?"
    - pattern: "--force"
      prompt: "Force operations can cause data loss. Are you sure?"

  database:
    - pattern: "DROP TABLE"
      prompt: "This will permanently delete a table. Are you sure?"
    - pattern: "TRUNCATE"
      prompt: "This will delete all data in the table. Are you sure?"
    - pattern: "DELETE FROM .* WHERE 1"
      prompt: "This will delete all rows. Are you sure?"

# Safety checks to perform before operations
pre_operation_checks:
  - check: "verify_working_directory"
    description: "Confirm we're in the expected project directory"
    when: "Before any file modification"

  - check: "verify_git_branch"
    description: "Confirm we're on the expected branch"
    when: "Before any git operation"

  - check: "verify_no_uncommitted_changes"
    description: "Check for uncommitted work that could be lost"
    when: "Before git reset, checkout, or clean"

  - check: "read_health_status"
    description: "Check if context has been compressed"
    when: "Before any destructive operation"

# What to do when safety is uncertain
uncertainty_protocol:
  steps:
    - "Read data/status.yaml to check context state"
    - "Read data/anchors/directory.anchor.yaml to verify location"
    - "Run 'pwd' and 'git status' to ground understanding"
    - "Ask user to confirm understanding before proceeding"

  phrases_to_use:
    - "Let me verify the current state before proceeding..."
    - "I notice context may have been compressed. Let me confirm..."
    - "Before this destructive operation, I want to verify..."
