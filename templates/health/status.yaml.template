# Dragonfly Context Health Status
# This file gives Claude awareness of its own context state
#
# Updated by: post-concept-action hook, pre-tool-grounding hook
# Read by: Claude before operations, /health command
#
# Claude should read this to calibrate confidence in its understanding

health_id: "health-current"
generated_at: "${TIMESTAMP}"
version: "1.0.0"

# ============================================================================
# TOKEN BUDGET STATUS
# ============================================================================
tokens:
  estimated_used: 0
  budget_total: 200000
  budget_remaining: 200000
  usage_percent: 0.0
  zone: "green"  # green (<70%), yellow (70-80%), red (>80%)

# Zone meanings:
#   green:  Safe to continue normally
#   yellow: Consider compacting, be more careful
#   red:    High risk of context loss, verify before acting

# ============================================================================
# COMPRESSION STATUS
# ============================================================================
compression:
  last_compaction: null
  compressions_this_session: 0
  data_potentially_lost: []
  # Example when compression occurs:
  # data_potentially_lost:
  #   - "Detailed error messages from turns 1-15"
  #   - "Specific file paths discussed early in session"
  #   - "Rationale for early decisions"

# ============================================================================
# SESSION CONTINUITY
# ============================================================================
session:
  started_at: "${TIMESTAMP}"
  interactions: 0
  concepts_executed: 0
  checkpoints_created: 0
  last_action: null
  # Example:
  # last_action:
  #   concept: "implementation"
  #   action: "generate"
  #   timestamp: "2025-12-05T10:30:00Z"

# ============================================================================
# GROUNDING STATUS
# ============================================================================
grounding:
  last_grounding_check: "${TIMESTAMP}"
  directory_verified: true
  rules_loaded: true
  anchors_current: true
  safety_constraints_active: true

# ============================================================================
# CONFIDENCE INDICATORS
# ============================================================================
confidence:
  overall: "high"  # high, medium, low
  factors:
    context_fresh: true
    no_compression: true
    anchors_loaded: true
    recent_verification: true

# Confidence meanings:
#   high:   Proceed normally
#   medium: Verify assumptions before destructive ops
#   low:    Re-read anchors, verify state before any action

# ============================================================================
# WARNINGS FOR CLAUDE TO SEE
# ============================================================================
warnings: []
# Example warnings:
# - type: "compression_occurred"
#   message: "Context was compressed 2 turns ago. Verify assumptions."
#   severity: "medium"
#   recommendation: "Re-read data/anchors/ before destructive operations"
#
# - type: "directory_mismatch"
#   message: "Working directory may have changed"
#   severity: "high"
#   recommendation: "Run 'pwd' to verify current location"
#
# - type: "long_session"
#   message: "Session has 50+ interactions, context may be degraded"
#   severity: "low"
#   recommendation: "Consider creating a checkpoint"

# ============================================================================
# RECOMMENDATIONS
# ============================================================================
recommendations: []
# Example recommendations based on state:
# - "Continue normally - context is healthy"
# - "Consider running /checkpoint before next major operation"
# - "Re-read data/anchors/rules.anchor.yaml to refresh safety rules"

# ============================================================================
# RECOVERY INFORMATION
# ============================================================================
recovery:
  last_checkpoint: null
  checkpoint_available: false
  # Example when checkpoint exists:
  # last_checkpoint: "ckpt-003-impl"
  # checkpoint_available: true
  # checkpoint_phase: "implementation_complete"
